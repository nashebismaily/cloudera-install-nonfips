#!/usr/bin/env bash

# -------------------------------------------------------------------
# Cloudera Auto-TLS location
# -------------------------------------------------------------------
export AUTO_TLS_LOCATION="/opt/cloudera/AutoTLS"
export AUTO_TLS_WORKDIR="${AUTO_TLS_LOCATION}/artifacts"

# Host inventory. Keep this as an absolute path for scripts and CM API clarity.
export AUTO_TLS_HOSTS_CSV="/root/cfm_fips_install/utilities/tls/hosts.csv"

# -------------------------------------------------------------------
# Passwords
# Set to true for encrypted host private keys, false for unencrypted host private keys.
export AUTO_TLS_ENCRYPT_HOST_KEYS="true"
# Keep these alphanumeric and longer than 12 characters for this flow.
# AUTO_TLS_HOST_KEY_PASSWORD encrypts host private PEM keys.
# 07 writes it into each cm-auto-host_key.pw file for Cert Manager.
# -------------------------------------------------------------------
export AUTO_TLS_HOST_KEY_PASSWORD="ChangeMe12345"
export AUTO_TLS_KEYSTORE_PASSWORD="ChangeMe12345"
export AUTO_TLS_TRUSTSTORE_PASSWORD="ChangeMe12345"

# Optional CA key password for the local CA helper scripts.
# If omitted, the scripts default it to AUTO_TLS_HOST_KEY_PASSWORD.
export AUTO_TLS_CA_KEY_PASSWORD="ChangeMe12345"

# -------------------------------------------------------------------
# Certificate subject defaults
# -------------------------------------------------------------------
export AUTO_TLS_COUNTRY="US"
export AUTO_TLS_STATE="VA"
export AUTO_TLS_LOCALITY="Reston"
export AUTO_TLS_ORG="Cloudera"
export AUTO_TLS_ORG_UNIT="Demo"
export AUTO_TLS_VALIDITY_DAYS="825"
export AUTO_TLS_CERT_DAYS="825"
export AUTO_TLS_CA_DAYS="3650"
export AUTO_TLS_CA_CN="CFM Internal CA"
export AUTO_TLS_KEY_SIZE="4096"
export AUTO_TLS_DIGEST="sha256"
export AUTO_TLS_STORE_TYPE="PKCS12"

# -------------------------------------------------------------------
# Artifact directories
# -------------------------------------------------------------------
export AUTO_TLS_KEY_DIR="${AUTO_TLS_WORKDIR}/keys"
export AUTO_TLS_CSR_DIR="${AUTO_TLS_WORKDIR}/csrs"
export AUTO_TLS_CERT_DIR="${AUTO_TLS_WORKDIR}/certs"
export AUTO_TLS_STORE_DIR="${AUTO_TLS_WORKDIR}/stores"
export AUTO_TLS_PAYLOAD_DIR="${AUTO_TLS_WORKDIR}/payload"
export AUTO_TLS_PAYLOAD_FILE="${AUTO_TLS_PAYLOAD_DIR}/generate_cmca_payload.json"

# -------------------------------------------------------------------
# Cloudera Manager API settings
# Before Auto-TLS: http://CM_HOST:7180
# After Auto-TLS:  https://CM_HOST:7183
# -------------------------------------------------------------------
export CM_HOST="ip-10-0-3-31.us-east-2.compute.internal"
export CM_PORT="7180"
export CM_API_VERSION="v41"
export CM_USER="admin"
export CM_PASSWORD="admin"

# -------------------------------------------------------------------
# SSH settings used by Auto-TLS
# The user must have passwordless SSH from the CM host to all hosts.
# If using a private key, provide AUTO_TLS_SSH_KEY_FILE.
# -------------------------------------------------------------------
export AUTO_TLS_SSH_USER="autotls"
export AUTO_TLS_SSH_PORT="22"
export AUTO_TLS_SSH_KEY_FILE="/home/autotls/.ssh/id_rsa"

# Whether CM should configure all services for TLS.
export AUTO_TLS_CONFIGURE_ALL_SERVICES="true"

# Java/keytool path for local PKCS12 validation/build steps.
export JAVA_HOME="${JAVA_HOME:-/usr/lib/jvm/java-11-openjdk}"
export KEYTOOL="${JAVA_HOME}/bin/keytool"
